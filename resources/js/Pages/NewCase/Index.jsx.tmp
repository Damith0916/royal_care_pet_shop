                                    <Beaker size={16} />
                                </div>
                                <h3 className="text-xs font-bold text-slate-900 tracking-tight">Lab findings</h3>
                            </div>
                            <div className="flex flex-wrap gap-2">
                                {record.lab_findings?.length > 0 ? record.lab_findings.map((finding, i) => (
