    Search,
    User,
    PawPrint,
    ChevronRight,
    History,
    Stethoscope,
    Activity,
    FileText,
    Dna,
    Plus,
    Minus,
    X,
    Trash2,
    Calendar,
    DollarSign,
    CheckCircle2,
    Printer,
    ClipboardList,
    AlertCircle,
    Thermometer,
    Weight,
    Layers,
    ShoppingCart,
    Edit2,
    UserPlus,
    PlusCircle,
    Shield,
    ShieldCheck,
    ChevronLeft,
    ChevronDown,
    ChevronUp,
