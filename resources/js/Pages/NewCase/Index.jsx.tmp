                    </div>
                    <button onClick={onClose} className="w-10 h-10 bg-white border border-slate-200 rounded-full flex items-center justify-center text-slate-600 hover:text-slate-900 transition-all shadow-sm">
                        <X size={20} />
                    </button>
                </div>

                {/* Modal Content */}
